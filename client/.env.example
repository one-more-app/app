# Dev : lu par Vite au démarrage.
VITE_API_URL="http://localhost:3000"

# Prod (Docker / Dokploy) : la même variable peut être définie sur le conteneur au runtime ;
# elle est injectée dans /runtime-env.js au démarrage (prioritaire sur la valeur du build).

# ---------------------------------------------------------------------------
# Mobile Capacitor — fichiers dédiés (VITE_* figées au build Vite)
# ---------------------------------------------------------------------------
# Templates : .env.dev.capacitor.example | .env.preprod.capacitor.example | .env.prod.capacitor.example
#
#   cp .env.dev.capacitor.example .env.dev.capacitor
#   cp .env.preprod.capacitor.example .env.preprod.capacitor
#   cp .env.prod.capacitor.example .env.prod.capacitor
#
# | Fichier                  | VITE_API_URL                          |
# |--------------------------|---------------------------------------|
# | .env.dev.capacitor       | http://localhost:3000                 |
# | .env.preprod.capacitor   | https://api.staging.one-more.app      |
# | .env.prod.capacitor      | https://api.one-more.app              |
#
# Scripts : npm run ios:build:prod | android:build:prod | build:mobile:*
# Règles Cursor : .cursor/rules/mobile-builds.mdc

# ---------------------------------------------------------------------------
# Google Sign-In natif (Capgo) — dans chaque .env.*.capacitor
# ---------------------------------------------------------------------------
# VITE_GOOGLE_WEB_CLIENT_ID  → Client OAuth Web (Android + vérif API)
# VITE_GOOGLE_CLIENT_ID_IOS  → Client OAuth iOS (bundle com.one-more.app)
#
# Flux : SocialLogin.login() → id_token → POST /oauth/google/id-token → JWT
# Côté api/.env : GOOGLE_CLIENT_ID_WEB + GOOGLE_CLIENT_ID_IOS (mêmes valeurs)
