# Template — copier vers .env.dev.capacitor
# Build Capacitor dev (API locale).
VITE_API_URL="http://localhost:3000"
VITE_GOOGLE_WEB_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID_IOS=""
# Bundle ID iOS (Sign in with Apple natif) — identique à PRODUCT_BUNDLE_IDENTIFIER
VITE_APPLE_CLIENT_ID="com.one-more.app"

# AppsFlyer (invitations OneLink) — voir docs/appsflyer-setup.md
# VITE_APPSFLYER_DEV_KEY=""
# VITE_APPSFLYER_APP_ID=""
# VITE_APPSFLYER_ONELINK_ID=""
# VITE_APPSFLYER_ONELINK_DOMAIN=""

# OpenPanel (analytics produit — KPIs, usage, satisfaction)
# VITE_OPENPANEL_CLIENT_ID=""
# VITE_OPENPANEL_API_URL="https://api.openpanel.dev"
# VITE_OPENPANEL_SESSION_REPLAY="true"
