{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "fetch:popular-exercises": "node scripts/fetch-popular-exercises.js",
    "fetch:popular-exercises:filter": "node scripts/fetch-popular-exercises.js --filter-only",
    "fetch:popular-exercises:filter-broken-images": "node scripts/fetch-popular-exercises.js --filter-broken-images",
    "dev": "vite",
    "dev:api": "npm --prefix ../api run start:dev",
    "dev:web": "vite",
    "dev:all": "concurrently -n web,api \"npm run dev:web\" \"npm run dev:api\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "wsl:android:build": "cd android && ./gradlew assembleDebug",
    "wsl:android:run": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk && adb shell monkey -p com.onemore.app 1",
    "wsl:android:dev": "npm run cap:sync && npm run wsl:android:build && npm run wsl:android:run",
    "assets:generate": "npx @capacitor/assets generate --iconBackgroundColor '#000000' --iconBackgroundColorDark '#000000' --splashBackgroundColor '#000000' --splashBackgroundColorDark '#000000' && rm -rf public/icons && mv icons public/icons && rm -f public/manifest.webmanifest && /bin/cp -f assets/logo.png public/logo.png"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/status-bar": "^8.0.1",
    "@capawesome/capacitor-app-review": "^8.0.1",
    "@ncdai/react-wheel-picker": "^1.2.0",
    "@radix-ui/react-progress": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "healthicons-react": "^3.5.0",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "lucide-react": "^0.569.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-joyride": "^3.0.2",
    "react-muscle-highlighter": "^1.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
