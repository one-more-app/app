DATABASE_URL="postgresql://onemore:onemore@localhost:5433/onemore?schema=public"

# Prod : origines du front autorisées pour CORS (séparées par des virgules). Exemple :
# CORS_ORIGINS="https://onemore.dokploy.moneyes.app"
# Quand CORS_ORIGINS est défini, `capacitor://localhost` (et origines Capacitor/Ionic
# associées) est toujours autorisé pour les builds mobile. En dev local, localhost:5173 l’est aussi.
# Si absent, le serveur renvoie l’Origin de la requête (souvent suffisant en local).

JWT_SECRET="change-me-in-prod"
JWT_EXPIRES_IN="15m"

# Push notifications (FCM via Firebase Admin). JSON du compte de service sur une ligne.
# Firebase Console → Paramètres du projet → Comptes de service → Générer une nouvelle clé privée.
# Coller le JSON minifié sur une ligne (guillemets simples recommandés). Ex. jq -c . fichier.json
# Si absent ou vide, les push sont désactivées (le reste de l'API fonctionne).
FIREBASE_SERVICE_ACCOUNT_JSON=""

# URL publique du client (web / PWA). Utilisée pour les liens d'invite en fallback.
PUBLIC_APP_URL="https://one-more.app"

# AppsFlyer OneLink (invitations amis). Si définis, les liens partagés passent par OneLink.
# APPSFLYER_ONELINK_DOMAIN="one-more.onelink.me"
# APPSFLYER_ONELINK_ID="H5hv"

# OpenPanel (analytics serveur — revenus, webhooks RevenueCat)
# OPENPANEL_CLIENT_ID=""
# OPENPANEL_CLIENT_SECRET=""
# OPENPANEL_API_URL="https://api.openpanel.dev"

# ---------------------------------------------------------------------------
# Google OAuth
# ---------------------------------------------------------------------------
#
# 1. Google Cloud Console → https://console.cloud.google.com/
#    - Créer ou sélectionner un projet (ex. one-more-app)
#    - APIs & Services → Library → activer Google Identity
#
# 2. OAuth consent screen (APIs & Services → OAuth consent screen)
#    - Type : External (ou Internal si Google Workspace)
#    - App name : One More, email support, logo
#    - Scopes : openid, email, profile
#    - Ajouter ton email comme Test user tant que l’app est en mode Testing
#
# 3. Credentials Web (Create → OAuth client ID → Web)
#    → GOOGLE_CLIENT_ID_WEB + VITE_GOOGLE_WEB_CLIENT_ID (client mobile)
#
# 4. Credentials Android (Create → OAuth client ID → Android)
#    - Package name : com.one_more.app
#    - SHA-1 debug :
#      keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android -keypass android
#    - SHA-1 release (depuis client/android) :
#      ./gradlew signingReport
#    → GOOGLE_CLIENT_ID_ANDROID
#
# 5. Credentials iOS (Create → OAuth client ID → iOS)
#    - Bundle ID : com.onemore.app
#    → GOOGLE_CLIENT_ID_IOS + VITE_GOOGLE_CLIENT_ID_IOS (client mobile)
#    - Ajouter le « iOS URL scheme » dans client/ios/App/App/Info.plist
#
# 6. Sign-In natif (Capgo) : POST /oauth/google/id-token
#    - Android : audience JWT = GOOGLE_CLIENT_ID_WEB
#    - iOS : audience JWT = GOOGLE_CLIENT_ID_IOS
#
# 7. Fallback web (PKCE Browser) : /oauth/google/start + /callback (legacy)
#
GOOGLE_CLIENT_ID_WEB=""
GOOGLE_CLIENT_ID_ANDROID=""
GOOGLE_CLIENT_ID_IOS=""
# Rétrocompatibilité (ancienne API) : utilisé si ANDROID/IOS absent
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
OAUTH_REDIRECT_URIS="com.one_more.app://oauth"

# Apple Sign-In
# - iOS natif (Capgo) : audience JWT = Bundle ID → APPLE_CLIENT_ID_IOS + VITE_APPLE_CLIENT_ID
APPLE_CLIENT_ID_IOS="com.one-more.app"
# - Android PKCE (navigateur) : Services ID + clé .p8 pour client_secret JWT
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
